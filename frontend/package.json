{
  "name": "xiaohongshu-generator-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "type-check": "vue-tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.9.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^3.2.7",
    "vue-tsc": "^3.3.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
